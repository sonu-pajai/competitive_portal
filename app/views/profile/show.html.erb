<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold text-slate-900 mb-8">My Profile</h1>

  <div class="bg-white rounded-2xl border border-slate-200 p-8 shadow-sm">
    <!-- Avatar -->
    <div class="flex items-center gap-4 mb-8 pb-8 border-b border-slate-100">
      <div class="w-16 h-16 rounded-full bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center">
        <span class="text-white text-xl font-bold"><%= current_user.name.first(2).upcase %></span>
      </div>
      <div>
        <h2 class="text-lg font-semibold text-slate-900"><%= current_user.name %></h2>
        <p class="text-sm text-slate-500"><%= current_user.email %></p>
        <p class="text-xs text-slate-400 mt-1">Member since <%= current_user.created_at.strftime("%B %Y") %></p>
      </div>
    </div>

    <%= form_with(model: current_user, url: profile_path, method: :patch) do |f| %>
      <% if current_user.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm mb-6">
          <% current_user.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
        </div>
      <% end %>

      <div class="space-y-5">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= f.text_field :name, class: "w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= f.email_field :email, class: "w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition" %>
        </div>

        <div>
          <%= f.label :phone, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= f.telephone_field :phone, class: "w-full border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition" %>
        </div>

        <%= f.submit "Save Changes", class: "btn-primary text-white font-semibold px-6 py-2.5 rounded-xl cursor-pointer text-sm" %>
      </div>
    <% end %>
  </div>
</div>
