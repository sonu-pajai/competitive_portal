<!-- Hero Section -->
<div class="relative overflow-hidden rounded-3xl mb-16">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-indigo-600 via-purple-600 to-violet-700"></div>
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg%20fill%3D%22none%22%20fill-rule%3D%22evenodd%22%3E%3Cg%20fill%3D%22%23ffffff%22%20fill-opacity%3D%220.05%22%3E%3Cpath%20d%3D%22M36%2034v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6%2034v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6%204V0H4v4H0v2h4v4h2V6h4V4H6z%22%2F%3E%3C%2Fg%3E%3C%2Fg%3E%3C%2Fsvg%3E')] opacity-30"></div>

  <!-- Decorative blobs -->
  <div class="absolute -top-20 -right-20 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-20 -left-20 w-60 h-60 bg-purple-400/20 rounded-full blur-3xl"></div>

  <div class="relative z-10 px-8 py-20 md:py-28 text-center">
    <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm text-white text-sm px-4 py-1.5 rounded-full mb-6 border border-white/20">
      <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
      India's #1 Exam Prep Platform
    </div>

    <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 leading-tight tracking-tight">
      Ace Your<br>
      <span class="bg-gradient-to-r from-amber-200 to-yellow-300 bg-clip-text text-transparent">Competitive Exams</span>
    </h1>

    <p class="text-lg md:text-xl text-indigo-100 mb-10 max-w-2xl mx-auto leading-relaxed">
      Premium video courses for UPSC, SSC, Banking, Railways & more — taught by India's top educators with view-limited premium content.
    </p>

    <div class="flex items-center justify-center gap-4 flex-wrap mb-12">
      <%= link_to courses_path, class: "btn-primary text-white font-semibold px-8 py-3.5 rounded-xl text-lg inline-flex items-center gap-2" do %>
        Browse Courses
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      <% end %>
      <% unless user_signed_in? %>
        <%= link_to "Create Free Account", new_user_registration_path, class: "border-2 border-white/30 text-white font-semibold px-8 py-3.5 rounded-xl text-lg hover:bg-white/10 transition backdrop-blur-sm" %>
      <% end %>
    </div>

    <!-- Stats -->
    <div class="inline-flex items-center gap-8 bg-white/10 backdrop-blur-sm rounded-2xl px-8 py-4 border border-white/10">
      <div class="text-center">
        <p class="text-2xl font-bold text-white"><%= User.student.count %>+</p>
        <p class="text-xs text-indigo-200 mt-0.5">Students</p>
      </div>
      <div class="w-px h-10 bg-white/20"></div>
      <div class="text-center">
        <p class="text-2xl font-bold text-white"><%= Course.published.count %></p>
        <p class="text-xs text-indigo-200 mt-0.5">Courses</p>
      </div>
      <div class="w-px h-10 bg-white/20"></div>
      <div class="text-center">
        <p class="text-2xl font-bold text-white"><%= Lesson.count %>+</p>
        <p class="text-xs text-indigo-200 mt-0.5">Video Lessons</p>
      </div>
      <div class="w-px h-10 bg-white/20"></div>
      <div class="text-center">
        <p class="text-2xl font-bold text-white">4.8★</p>
        <p class="text-xs text-indigo-200 mt-0.5">Rating</p>
      </div>
    </div>
  </div>
</div>

<!-- Exam Categories -->
<div class="mb-16">
  <div class="text-center mb-8">
    <h2 class="text-2xl font-bold text-slate-900">Prepare for Top Exams</h2>
    <p class="text-slate-500 mt-2">Choose your exam category and start preparing today</p>
  </div>
  <div class="flex flex-wrap justify-center gap-3">
    <% Course.published.distinct.pluck(:exam_category).compact.each do |cat| %>
      <%= link_to cat, courses_path(category: cat), class: "px-5 py-2.5 bg-white border border-slate-200 rounded-full text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50 transition shadow-sm" %>
    <% end %>
  </div>
</div>

<!-- Featured Courses -->
<% if @featured_courses.any? %>
  <div class="mb-16">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h2 class="text-2xl font-bold text-slate-900">Featured Courses</h2>
        <p class="text-slate-500 mt-1">Handpicked courses to kickstart your preparation</p>
      </div>
      <%= link_to "View all →", courses_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800 transition" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @featured_courses.each do |course| %>
        <%= link_to course_path(course), class: "group bg-white rounded-2xl border border-slate-200 overflow-hidden card-hover block" do %>
          <div class="relative">
            <% if course.thumbnail_url.present? %>
              <img src="<%= course.thumbnail_url %>" alt="<%= course.title %>" class="w-full h-44 object-cover group-hover:scale-105 transition duration-500">
            <% else %>
              <div class="w-full h-44 bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center group-hover:scale-105 transition duration-500">
                <span class="text-white text-3xl font-bold opacity-50"><%= course.exam_category %></span>
              </div>
            <% end %>
            <div class="absolute top-3 left-3">
              <span class="bg-white/90 backdrop-blur-sm text-indigo-700 text-xs font-semibold px-3 py-1 rounded-full shadow-sm"><%= course.exam_category %></span>
            </div>
          </div>
          <div class="p-5">
            <h3 class="text-base font-semibold text-slate-900 mb-2 group-hover:text-indigo-600 transition"><%= course.title %></h3>
            <p class="text-slate-500 text-sm mb-4 line-clamp-2 leading-relaxed"><%= course.description %></p>
            <div class="flex justify-between items-center pt-3 border-t border-slate-100">
              <div>
                <span class="text-lg font-bold text-indigo-600">
                  <% if course.price.zero? %>Free<% else %>₹<%= number_with_delimiter(course.price) %><% end %>
                </span>
              </div>
              <div class="flex items-center gap-1 text-xs text-slate-400">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <%= course.lesson_count %> lessons
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Why Choose Us -->
