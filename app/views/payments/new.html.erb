<div class="max-w-lg mx-auto">
  <div class="bg-white rounded-xl shadow-sm border p-8 text-center">
    <h1 class="text-2xl font-bold mb-4">Complete Payment</h1>
    <p class="text-gray-600 mb-2">Course: <strong><%= @payment.enrollment.course.title %></strong></p>
    <p class="text-3xl font-bold text-indigo-600 mb-6">₹<%= number_with_delimiter(@payment.amount) %></p>

    <button id="pay-btn" class="bg-indigo-600 text-white px-8 py-3 rounded-lg text-lg hover:bg-indigo-700">
      Pay with Razorpay
    </button>

    <% if Rails.env.development? %>
      <div class="mt-4 pt-4 border-t">
        <%= button_to "✅ Test Pay (Skip Razorpay)", verify_payment_path(@payment, razorpay_order_id: params[:order_id], razorpay_payment_id: "pay_test_#{SecureRandom.hex(8)}", razorpay_signature: "test", test_mode: true), class: "text-sm bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700" %>
      </div>
    <% end %>
  </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  document.getElementById('pay-btn').addEventListener('click', function() {
    var options = {
      key: '<%= @razorpay_key %>',
      amount: '<%= (@payment.amount * 100).to_i %>',
      currency: 'INR',
      name: 'ExamPrep Portal',
      description: '<%= @payment.enrollment.course.title %>',
      order_id: '<%= params[:order_id] %>',
      handler: function(response) {
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '<%= verify_payment_path(@payment) %>';

        var fields = {
          'authenticity_token': '<%= form_authenticity_token %>',
          'razorpay_payment_id': response.razorpay_payment_id,
          'razorpay_order_id': response.razorpay_order_id,
          'razorpay_signature': response.razorpay_signature
        };

        for (var key in fields) {
          var input = document.createElement('input');
          input.type = 'hidden';
          input.name = key;
          input.value = fields[key];
          form.appendChild(input);
        }

        document.body.appendChild(form);
        form.submit();
      },
      prefill: {
        email: '<%= current_user.email %>',
        contact: '<%= current_user.phone %>'
      },
      method: {
        card: true,
        netbanking: true,
        upi: true,
        wallet: true
      },
      theme: { color: '#4F46E5' }
    };

    var rzp = new Razorpay(options);
    rzp.open();
  });
</script>
