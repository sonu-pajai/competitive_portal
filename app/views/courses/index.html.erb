<div class="mb-8">
  <h1 class="text-3xl font-bold text-slate-900">Explore Courses</h1>
  <p class="text-slate-500 mt-1">Find the perfect course for your exam preparation</p>
</div>

<!-- Filters -->
<div class="bg-white rounded-2xl border border-slate-200 p-4 mb-8">
  <%= form_tag courses_path, method: :get, class: "flex gap-3 items-center flex-wrap" do %>
    <div class="flex-1 min-w-[200px] relative">
      <svg class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <%= text_field_tag :q, @q, placeholder: "Search courses...", class: "w-full border border-slate-200 rounded-xl pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition" %>
    </div>
    <%= select_tag :category, options_for_select(Course.distinct.pluck(:exam_category).compact, @category), include_blank: "All Categories", class: "border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 transition bg-white" %>
    <%= submit_tag "Search", class: "btn-primary text-white text-sm font-medium px-6 py-2.5 rounded-xl cursor-pointer" %>
    <% if @q.present? || @category.present? %>
      <%= link_to "Clear", courses_path, class: "text-sm text-slate-400 hover:text-slate-600 transition" %>
    <% end %>
  <% end %>
</div>

<!-- Course Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
  <% @courses.each do |course| %>
    <div class="group bg-white rounded-2xl border border-slate-200 overflow-hidden card-hover">
      <div class="relative">
        <% if course.thumbnail_url.present? %>
          <img src="<%= course.thumbnail_url %>" alt="<%= course.title %>" class="w-full h-44 object-cover group-hover:scale-105 transition duration-500">
        <% else %>
          <div class="w-full h-44 bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center group-hover:scale-105 transition duration-500">
            <span class="text-white text-3xl font-bold opacity-50"><%= course.exam_category %></span>
          </div>
        <% end %>
        <div class="absolute top-3 left-3">
          <span class="bg-white/90 backdrop-blur-sm text-indigo-700 text-xs font-semibold px-3 py-1 rounded-full shadow-sm"><%= course.exam_category %></span>
        </div>
      </div>
      <div class="p-5">
        <h3 class="text-base font-semibold text-slate-900 mb-2 group-hover:text-indigo-600 transition"><%= course.title %></h3>
        <p class="text-slate-500 text-sm mb-4 line-clamp-2 leading-relaxed"><%= course.description %></p>

        <div class="flex items-center gap-3 text-xs text-slate-400 mb-4">
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <%= course.lesson_count %> lessons
          </span>
          <span>•</span>
          <span><%= course.duration_days %> days access</span>
        </div>

        <div class="flex justify-between items-center pt-4 border-t border-slate-100">
          <span class="text-xl font-bold text-indigo-600">
            <% if course.price.zero? %><span class="text-emerald-600">Free</span><% else %>₹<%= number_with_delimiter(course.price) %><% end %>
          </span>
          <%= link_to course_path(course), class: "btn-primary text-white text-sm font-medium px-5 py-2 rounded-lg inline-flex items-center gap-1.5" do %>
            View
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if @courses.empty? %>
  <div class="bg-white rounded-2xl border border-slate-200 p-16 text-center">
    <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <p class="text-slate-500 text-lg">No courses found</p>
    <p class="text-slate-400 text-sm mt-1">Try adjusting your search or filters</p>
  </div>
<% end %>

<div class="mt-8">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
