<div class="max-w-4xl mx-auto">
  <!-- Course Header -->
  <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden mb-8">
    <% if @course.thumbnail_url.present? %>
      <div class="relative h-64">
        <img src="<%= @course.thumbnail_url %>" alt="<%= @course.title %>" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
        <div class="absolute bottom-6 left-8">
          <span class="bg-white/90 backdrop-blur-sm text-indigo-700 text-xs font-semibold px-3 py-1 rounded-full"><%= @course.exam_category %></span>
        </div>
      </div>
    <% end %>

    <div class="p-8">
      <% unless @course.thumbnail_url.present? %>
        <span class="inline-block bg-indigo-100 text-indigo-700 text-xs font-semibold px-3 py-1 rounded-full mb-4"><%= @course.exam_category %></span>
      <% end %>

      <h1 class="text-3xl font-bold text-slate-900 mb-3"><%= @course.title %></h1>
      <p class="text-slate-600 leading-relaxed mb-6"><%= @course.description %></p>

      <!-- Course Meta -->
      <div class="flex flex-wrap gap-6 mb-8">
        <div class="flex items-center gap-2 text-sm text-slate-500">
          <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <strong><%= @course.lesson_count %></strong> Lessons
        </div>
        <div class="flex items-center gap-2 text-sm text-slate-500">
          <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Valid for <strong><%= @course.duration_days %></strong> days
        </div>
        <div class="flex items-center gap-2 text-sm text-slate-500">
          <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          DRM Protected
        </div>
      </div>

      <!-- Price & CTA -->
      <div class="flex items-center gap-6 p-6 bg-slate-50 rounded-2xl">
        <div>
          <p class="text-xs text-slate-400 mb-1">Course Price</p>
          <span class="text-3xl font-bold gradient-text">
            <% if @course.price.zero? %>Free<% else %>₹<%= number_with_delimiter(@course.price) %><% end %>
          </span>
        </div>
        <div class="flex-1"></div>
        <% if @enrolled %>
          <%= link_to course_lessons_path(@course), class: "bg-emerald-600 text-white font-semibold px-8 py-3.5 rounded-xl hover:bg-emerald-700 transition inline-flex items-center gap-2 shadow-lg shadow-emerald-500/20" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Go to Lessons
          <% end %>
        <% elsif user_signed_in? %>
          <%= button_to enroll_course_path(@course), class: "btn-primary text-white font-semibold px-8 py-3.5 rounded-xl inline-flex items-center gap-2 shadow-lg shadow-indigo-500/20" do %>
            Enroll Now
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          <% end %>
        <% else %>
          <%= link_to new_user_session_path, class: "btn-primary text-white font-semibold px-8 py-3.5 rounded-xl inline-flex items-center gap-2 shadow-lg shadow-indigo-500/20" do %>
            Login to Enroll
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Course Content -->
  <div class="mb-8">
    <h2 class="text-xl font-bold text-slate-900 mb-4">Course Content</h2>
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
      <% @course.lessons.each_with_index do |lesson, i| %>
        <div class="flex items-center gap-4 p-4 <%= i > 0 ? 'border-t border-slate-100' : '' %> hover:bg-slate-50 transition">
          <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center shrink-0">
            <span class="text-xs font-bold text-indigo-600"><%= i + 1 %></span>
          </div>
          <div class="flex-1">
            <p class="font-medium text-slate-900 text-sm"><%= lesson.title %></p>
          </div>
          <div class="flex items-center gap-2 text-xs text-slate-400">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            <%= lesson.max_views %> views
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
