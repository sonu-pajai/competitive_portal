<h1 class="text-2xl font-bold text-slate-900 mb-8">My Courses</h1>

<% if @active_enrollments.any? %>
  <h2 class="text-lg font-semibold text-slate-800 mb-4">Active</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
    <% @active_enrollments.each do |enrollment| %>
      <div class="group bg-white rounded-2xl border border-slate-200 overflow-hidden card-hover">
        <% if enrollment.course.thumbnail_url.present? %>
          <img src="<%= enrollment.course.thumbnail_url %>" class="w-full h-36 object-cover group-hover:scale-105 transition duration-500">
        <% else %>
          <div class="w-full h-36 bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
            <span class="text-white text-2xl font-bold opacity-50"><%= enrollment.course.exam_category %></span>
          </div>
        <% end %>
        <div class="p-5">
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200 mb-3">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Active
          </span>
          <h3 class="font-semibold text-slate-900 mb-1"><%= enrollment.course.title %></h3>
          <p class="text-xs text-slate-400 mb-4">Expires: <%= enrollment.expires_at&.strftime("%d %b %Y") %></p>
          <%= link_to course_lessons_path(enrollment.course), class: "btn-primary text-white text-sm font-medium px-4 py-2 rounded-lg inline-flex items-center gap-1.5" do %>
            Continue Learning
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 p-16 text-center mb-10">
    <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
    <p class="text-slate-500 text-lg">No active courses</p>
    <p class="text-slate-400 text-sm mt-1 mb-4">Start your preparation today</p>
    <%= link_to "Browse Courses", courses_path, class: "btn-primary text-white text-sm font-medium px-6 py-2.5 rounded-xl" %>
  </div>
<% end %>

<% if @expired_enrollments.any? %>
  <h2 class="text-lg font-semibold text-slate-800 mb-4">Expired</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @expired_enrollments.each do |enrollment| %>
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden opacity-60">
        <% if enrollment.course.thumbnail_url.present? %>
          <img src="<%= enrollment.course.thumbnail_url %>" class="w-full h-36 object-cover grayscale">
        <% end %>
        <div class="p-5">
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-red-50 text-red-600 border border-red-200 mb-3">Expired</span>
          <h3 class="font-semibold text-slate-900 mb-1"><%= enrollment.course.title %></h3>
          <p class="text-xs text-slate-400 mb-4">Expired: <%= enrollment.expires_at&.strftime("%d %b %Y") %></p>
          <%= link_to "Re-enroll →", course_path(enrollment.course), class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium" %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
