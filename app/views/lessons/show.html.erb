<div class="max-w-4xl mx-auto">
  <%= link_to "← Back to Lessons", course_lessons_path(@course), class: "text-indigo-600 hover:text-indigo-800 mb-4 inline-block" %>

  <div class="bg-white rounded-xl shadow-sm border p-8">
    <h1 class="text-2xl font-bold mb-4"><%= @lesson.title %></h1>
    <p class="text-gray-600 mb-6"><%= @lesson.description %></p>

    <div class="flex items-center gap-4">
      <% if @views_remaining > 0 %>
        <%= link_to "▶ Watch Video", watch_course_lesson_path(@course, @lesson), class: "bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700" %>
        <span class="text-sm text-gray-500"><%= @views_remaining %> views remaining</span>
      <% else %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg">
          You have used all <%= @lesson.max_views %> views for this lesson.
        </div>
      <% end %>
    </div>
  </div>
</div>
