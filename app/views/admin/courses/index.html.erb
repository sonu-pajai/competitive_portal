<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">Courses</h1>
  <%= link_to "New Course", new_admin_course_path, class: "bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700" %>
</div>

<div class="bg-white rounded-xl shadow-sm border overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="text-left px-4 py-3">Title</th>
        <th class="text-left px-4 py-3">Category</th>
        <th class="text-left px-4 py-3">Price</th>
        <th class="text-left px-4 py-3">Status</th>
        <th class="text-left px-4 py-3">Lessons</th>
        <th class="text-left px-4 py-3">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @courses.each do |course| %>
        <tr>
          <td class="px-4 py-3 font-medium"><%= course.title %></td>
          <td class="px-4 py-3"><%= course.exam_category %></td>
          <td class="px-4 py-3">₹<%= number_with_delimiter(course.price) %></td>
          <td class="px-4 py-3">
            <span class="px-2 py-1 rounded text-xs <%= course.published? ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
              <%= course.status.capitalize %>
            </span>
          </td>
          <td class="px-4 py-3"><%= link_to "#{course.lesson_count} lessons", admin_course_lessons_path(course), class: "text-indigo-600" %></td>
          <td class="px-4 py-3 space-x-2">
            <%= link_to "Edit", edit_admin_course_path(course), class: "text-indigo-600" %>
            <%= button_to "Delete", admin_course_path(course), method: :delete, class: "text-red-500", data: { turbo_confirm: "Delete this course?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
