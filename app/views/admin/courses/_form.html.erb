<%= form_with(model: [:admin, @course], class: "space-y-4") do |f| %>
  <% if @course.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
      <% @course.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, class: "w-full border rounded-lg px-4 py-2" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4, class: "w-full border rounded-lg px-4 py-2" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :price, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :price, step: 0.01, class: "w-full border rounded-lg px-4 py-2" %>
    </div>
    <div>
      <%= f.label :exam_category, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :exam_category, placeholder: "e.g. UPSC, SSC, Banking", class: "w-full border rounded-lg px-4 py-2" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status, Course.statuses.keys.map { |s| [s.capitalize, s] }, {}, class: "w-full border rounded-lg px-4 py-2" %>
    </div>
    <div>
      <%= f.label :duration_days, "Validity (days)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :duration_days, class: "w-full border rounded-lg px-4 py-2" %>
    </div>
  </div>

  <div>
    <%= f.label :thumbnail, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.file_field :thumbnail, class: "w-full border rounded-lg px-4 py-2" %>
  </div>

  <%= f.submit class: "bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
<% end %>
