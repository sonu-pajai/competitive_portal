<h1 class="text-2xl font-bold mb-6">Payments</h1>

<div class="flex gap-2 mb-6">
  <%= link_to "All", admin_payments_path, class: "px-4 py-2 rounded-lg #{params[:status].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-200'}" %>
  <% Payment.statuses.keys.each do |s| %>
    <%= link_to s.capitalize, admin_payments_path(status: s), class: "px-4 py-2 rounded-lg #{params[:status] == s ? 'bg-indigo-600 text-white' : 'bg-gray-200'}" %>
  <% end %>
</div>

<div class="bg-white rounded-xl shadow-sm border overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="text-left px-4 py-3">User</th>
        <th class="text-left px-4 py-3">Course</th>
        <th class="text-left px-4 py-3">Amount</th>
        <th class="text-left px-4 py-3">Status</th>
        <th class="text-left px-4 py-3">Razorpay ID</th>
        <th class="text-left px-4 py-3">Date</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @payments.each do |payment| %>
        <tr>
          <td class="px-4 py-3"><%= link_to payment.user.name, admin_user_path(payment.user), class: "text-indigo-600" %></td>
          <td class="px-4 py-3"><%= payment.enrollment.course.title %></td>
          <td class="px-4 py-3">₹<%= number_with_delimiter(payment.amount) %></td>
          <td class="px-4 py-3">
            <span class="px-2 py-1 rounded text-xs <%= payment.paid? ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
              <%= payment.status.capitalize %>
            </span>
          </td>
          <td class="px-4 py-3 text-xs text-gray-400"><%= payment.razorpay_payment_id %></td>
          <td class="px-4 py-3"><%= payment.created_at.strftime("%d %b %Y %H:%M") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
